{
  "manifest_version": 3,
  "name": "Page Repair",
  "version": "1.0.0",
  "description": "Fixes broken pages for screen reader users: labels unlabeled controls, repairs headings and landmarks. Always user-invoked.",
  "homepage_url": "https://github.com/Beaudoin0zach/page-repair",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab", "scripting", "notifications"],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://page-repair-proxy.airboat-webcast-5u.workers.dev/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Repair this page (Alt+Shift+R)",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "repair-page": {
      "suggested_key": {
        "default": "Alt+Shift+R"
      },
      "description": "Repair the current page for screen reader navigation"
    },
    "undo-repairs": {
      "suggested_key": {
        "default": "Alt+Shift+U"
      },
      "description": "Undo all repairs on the current page"
    },
    "copy-audit-report": {
      "description": "Copy an accessibility report for this page to the clipboard"
    }
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  }
}
